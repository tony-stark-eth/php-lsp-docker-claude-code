{
  "name": "php-lsp-docker-claude-code",
  "description": "PHP LSP servers (Intelephense + PHPantom) running in Docker for Claude Code",
  "homepage": "https://github.com/tony-stark-eth/php-lsp-docker-claude-code",
  "owner": {
    "name": "tony-stark-eth",
    "url": "https://github.com/tony-stark-eth"
  },
  "plugins": [
    {
      "name": "intelephense-docker",
      "source": "./intelephense",
      "description": "Intelephense PHP LSP via Docker (free tier)",
      "tags": ["php", "lsp", "intelephense"],
      "lspServers": {
        "php": {
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/lsp-server.sh",
          "args": [],
          "extensionToLanguage": {
            ".php": "php",
            ".phtml": "php",
            ".php3": "php",
            ".php4": "php",
            ".php5": "php",
            ".php7": "php",
            ".php8": "php",
            ".phps": "php",
            ".phar": "php"
          },
          "startupTimeout": 30000
        }
      }
    },
    {
      "name": "phpantom-docker",
      "source": "./phpantom",
      "description": "PHPantom ultra-fast Rust PHP LSP via Docker",
      "tags": ["php", "lsp", "phpantom", "rust"],
      "lspServers": {
        "php": {
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/lsp-server.sh",
          "args": [],
          "extensionToLanguage": {
            ".php": "php",
            ".phtml": "php",
            ".php3": "php",
            ".php4": "php",
            ".php5": "php",
            ".php7": "php",
            ".php8": "php",
            ".phps": "php",
            ".phar": "php"
          },
          "startupTimeout": 30000
        }
      }
    },
    {
      "name": "php-combined-docker",
      "source": "./combined",
      "description": "Intelephense + PHPantom running together — completions, diagnostics and definitions merged from both servers",
      "tags": ["php", "lsp", "intelephense", "phpantom", "docker"],
      "lspServers": {
        "php": {
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/lsp-server.sh",
          "args": [],
          "extensionToLanguage": {
            ".php": "php",
            ".phtml": "php",
            ".php3": "php",
            ".php4": "php",
            ".php5": "php",
            ".php7": "php",
            ".php8": "php",
            ".phps": "php",
            ".phar": "php"
          },
          "startupTimeout": 180000
        }
      }
    }
  ]
}
